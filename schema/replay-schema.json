{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/Killriam/mtg-replay-notation/schema/replay-schema.json",
    "title": "MTG Replay Notation",
    "description": "Schema for MTG Replay & Learning Notation v1.6.0",
    "type": "object",
    "required": ["format", "version", "meta", "seed", "card_index", "initial_state", "log_l1"],
    "properties": {
        "format": {
            "type": "string",
            "const": "mtg-replay",
            "description": "Format identifier"
        },
        "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
            "description": "Semantic version of the format"
        },
        "meta": {
            "$ref": "#/definitions/ReplayMeta"
        },
        "seed": {
            "type": "integer",
            "description": "Random seed for deterministic replay"
        },
        "game_start": {
            "$ref": "#/definitions/GameStart",
            "description": "Pre-game decisions (toss, mulligans)"
        },
        "card_index": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/definitions/CardDefinition"
            },
            "description": "Map of card names to their definitions"
        },
        "initial_state": {
            "$ref": "#/definitions/GameState"
        },
        "log_l1": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/L1Event"
            },
            "description": "Level 1 event log"
        },
        "views_l2": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/L2Unit"
            },
            "description": "Level 2 learning units"
        },
        "decklist": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/definitions/CommanderDecklist"
            },
            "description": "Optional map of player ID to inline commander decklist (v1.6.0+)"
        }
    },
    "definitions": {
        "ReplayMeta": {
            "type": "object",
            "required": ["game_id", "timestamp", "game_type", "players"],
            "properties": {
                "game_id": {
                    "type": "string",
                    "description": "Unique identifier for this game"
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time",
                    "description": "When game started (ISO 8601)"
                },
                "game_type": {
                    "type": "string",
                    "description": "Format (Constructed, Limited, Commander, etc.)"
                },
                "players": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/PlayerMeta"
                    }
                },
                "winner": {
                    "type": ["string", "null"],
                    "description": "Player ID of winner, 'draw', or null"
                },
                "win_condition": {
                    "type": "string",
                    "enum": ["life_zero", "commander_damage", "decked", "poison", "concession", "alternate_win", "draw"],
                    "description": "How the game ended"
                },
                "conceded": {
                    "type": "boolean",
                    "description": "Whether any player conceded"
                },
                "turns": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Total number of turns played"
                },
                "duration_seconds": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Real-time duration of game"
                }
            }
        },
        "PlayerMeta": {
            "type": "object",
            "required": ["name"],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Player display name"
                },
                "deck_name": {
                    "type": "string",
                    "description": "Name of the deck used"
                },
                "deck_hash": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{16}$",
                    "description": "SHA-256 based deck identifier (16 hex chars)"
                }
            }
        },
        "GameStart": {
            "type": "object",
            "properties": {
                "toss_winner": {
                    "type": "string",
                    "description": "Player who won the die roll/coin toss"
                },
                "play_draw_choice": {
                    "type": "string",
                    "enum": ["play", "draw"],
                    "description": "Choice made by toss winner"
                },
                "starting_player": {
                    "type": "string",
                    "description": "Player who takes the first turn"
                },
                "mulligans": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/MulliganSummary"
                    },
                    "description": "Mulligan decisions per player"
                }
            }
        },
        "MulliganSummary": {
            "type": "object",
            "required": ["player", "mulligans_taken", "final_hand_size"],
            "properties": {
                "player": {
                    "type": "string",
                    "description": "Player ID"
                },
                "starting_hand_size": {
                    "type": "integer",
                    "description": "Initial hand size (usually 7)"
                },
                "mulligans_taken": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Number of times player mulliganed"
                },
                "final_hand_size": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Cards in hand after all mulligans"
                },
                "cards_to_bottom": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Cards put on bottom (London mulligan)"
                }
            }
        },
        "CardDefinition": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "English card name"
                },
                "cost": {
                    "type": "string",
                    "description": "Mana cost in standard notation"
                },
                "type": {
                    "type": "string",
                    "description": "Full type line"
                },
                "oracle_id": {
                    "type": "string",
                    "description": "Scryfall Oracle ID"
                }
            }
        },
        "GameState": {
            "type": "object",
            "properties": {
                "turn": {
                    "type": "integer",
                    "minimum": 0
                },
                "phase": {
                    "type": "string"
                },
                "step": {
                    "type": "string"
                },
                "priority": {
                    "type": ["string", "null"]
                },
                "active_player": {
                    "type": ["string", "null"]
                },
                "players": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/PlayerState"
                    }
                },
                "zones": {
                    "type": "object",
                    "additionalProperties": {
                        "oneOf": [
                            { "type": "array", "items": { "type": "string" } },
                            { "type": "object", "properties": { "count": { "type": "integer" } } }
                        ]
                    }
                },
                "objects": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/ObjectState"
                    }
                }
            }
        },
        "PlayerState": {
            "type": "object",
            "properties": {
                "life": {
                    "type": "integer"
                },
                "mana_pool": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "counters": {
                    "type": "object",
                    "additionalProperties": { "type": "integer" }
                },
                "lands_played_this_turn": {
                    "type": "integer",
                    "minimum": 0
                },
                "max_hand_size": {
                    "type": "integer"
                }
            }
        },
        "ObjectState": {
            "type": "object",
            "required": ["card_ref", "controller", "owner", "zone"],
            "properties": {
                "card_ref": {
                    "type": "string",
                    "description": "Reference to card in card_index"
                },
                "controller": {
                    "type": "string"
                },
                "owner": {
                    "type": "string"
                },
                "zone": {
                    "type": "string"
                },
                "tapped": {
                    "type": "boolean"
                },
                "flipped": {
                    "type": "boolean"
                },
                "face_down": {
                    "type": "boolean"
                },
                "counters": {
                    "type": "object",
                    "additionalProperties": { "type": "integer" }
                },
                "damage_marked": {
                    "type": "integer",
                    "minimum": 0
                },
                "attached_to": {
                    "type": ["string", "null"]
                },
                "notes": {
                    "type": "object"
                }
            }
        },
        "L1Event": {
            "type": "object",
            "required": ["i", "t", "a", "type", "data"],
            "properties": {
                "i": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Event index"
                },
                "t": {
                    "type": "string",
                    "pattern": "^T[0-9]+\\.[A-Z0-9_]+(:[0-9]+)?$",
                    "description": "Time marker"
                },
                "a": {
                    "type": "string",
                    "enum": ["P1", "P2", "P3", "P4", "SYS"],
                    "description": "Actor"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "CAST", "ACTIVATE", "PLAY_LAND", "DECLARE_ATTACKERS", 
                        "DECLARE_BLOCKERS", "PASS_PRIORITY", "MULLIGAN", "CHOOSE",
                        "LEARNING_MARKER",
                        "PUT_ON_STACK", "TRIGGER", "RESOLVE", "MOVE", "DAMAGE",
                        "LIFE", "COUNTERS", "TAP", "PHASE_CHANGE", "RESOURCES",
                        "STATE_BASED", "RANDOM",
                        "DRAW", "GAME_START", "ACTIVE_PLAYER_CHANGE"
                    ],
                    "description": "Event type"
                },
                "data": {
                    "type": "object",
                    "description": "Event-specific payload"
                }
            }
        },
        "L2Unit": {
            "type": "object",
            "required": ["u", "t_start", "t_end", "l1_range", "before", "after"],
            "properties": {
                "u": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Unit index"
                },
                "t_start": {
                    "type": "string",
                    "description": "Starting time marker"
                },
                "t_end": {
                    "type": "string",
                    "description": "Ending time marker"
                },
                "l1_range": {
                    "type": "array",
                    "items": { "type": "integer" },
                    "minItems": 2,
                    "maxItems": 2,
                    "description": "Range of L1 event indices [start, end]"
                },
                "decision_events": {
                    "type": "array",
                    "items": { "type": "integer" },
                    "description": "Indices of decision events"
                },
                "before": {
                    "$ref": "#/definitions/GameState"
                },
                "stack": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/StackItem"
                    }
                },
                "after": {
                    "$ref": "#/definitions/GameState"
                },
                "annotations": {
                    "$ref": "#/definitions/Annotations"
                }
            }
        },
        "StackItem": {
            "type": "object",
            "required": ["stack", "kind", "controller"],
            "properties": {
                "stack": {
                    "type": "string",
                    "description": "Stack object ID"
                },
                "kind": {
                    "type": "string",
                    "enum": ["SPELL", "ABILITY", "TRIGGER"]
                },
                "controller": {
                    "type": "string"
                },
                "source": {
                    "type": "string"
                },
                "card": {
                    "type": "string"
                },
                "card_name": {
                    "type": "string"
                },
                "targets": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/Target"
                    }
                },
                "choices": {
                    "type": "object"
                },
                "linked_decision_event": {
                    "type": "integer"
                },
                "mana_paid": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "outcome": {
                    "type": "string",
                    "enum": ["resolved", "countered", "fizzled", "exiled"]
                }
            }
        },
        "Target": {
            "type": "object",
            "required": ["slot", "obj"],
            "properties": {
                "slot": {
                    "type": "string",
                    "description": "Target slot name"
                },
                "obj": {
                    "type": "string",
                    "description": "Target object ID"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable name"
                },
                "valid": {
                    "type": "boolean",
                    "description": "Whether target was legal"
                }
            }
        },
        "Annotations": {
            "type": "object",
            "properties": {
                "decision_quality": {
                    "description": "Quality score (format varies)"
                },
                "alternative_lines": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "key_moment": {
                    "type": "boolean"
                },
                "teaching_notes": {
                    "type": "string"
                }
            }
        },
        "CommanderDecklist": {
            "type": "object",
            "required": ["format", "version", "meta", "commander", "main"],
            "description": "Commander format decklist with mechanic roles, mulligan rules, and combo declarations",
            "properties": {
                "format": {
                    "type": "string",
                    "const": "mtg-commander-decklist",
                    "description": "Format identifier for commander decklists"
                },
                "version": {
                    "type": "string",
                    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
                    "description": "Semantic version of the decklist format"
                },
                "meta": {
                    "$ref": "#/definitions/DecklistMeta"
                },
                "commander": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/definitions/DecklistCard" },
                    "description": "Cards that start in the command zone (commander, partner, background, companion)"
                },
                "main": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/DecklistCard" },
                    "description": "Main deck cards (99 cards in Commander, or 98 when using a companion)"
                },
                "sideboard": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/DecklistCard" },
                    "description": "Sideboard cards (excluded from deck_hash)"
                },
                "maybeboard": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/DecklistCard" },
                    "description": "Considered but not included cards (excluded from deck_hash)"
                },
                "deck_rules": {
                    "$ref": "#/definitions/DeckRules",
                    "description": "Strategic rules: mulligan scoring, combo declarations, anti-synergies"
                }
            }
        },
        "DecklistMeta": {
            "type": "object",
            "required": ["deck_name", "format"],
            "description": "Metadata describing the decklist",
            "properties": {
                "deck_id": {
                    "type": "string",
                    "description": "Unique identifier for the deck (UUID recommended)"
                },
                "deck_name": {
                    "type": "string",
                    "description": "Display name for the deck"
                },
                "format": {
                    "type": "string",
                    "const": "Commander",
                    "description": "Must be 'Commander'"
                },
                "colors": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": ["W", "U", "B", "R", "G"]
                    },
                    "description": "Color identity as WUBRG letters"
                },
                "created": {
                    "type": "string",
                    "format": "date",
                    "description": "Creation date (ISO 8601, e.g., '2026-03-11')"
                },
                "updated": {
                    "type": "string",
                    "format": "date",
                    "description": "Last modification date (ISO 8601)"
                },
                "author": {
                    "type": "string",
                    "description": "Name or username of the deck builder"
                },
                "description": {
                    "type": "string",
                    "description": "Free-text description of the deck strategy"
                }
            }
        },
        "DecklistCard": {
            "type": "object",
            "required": ["quantity", "name", "edition", "collector_number", "primary_mechanic"],
            "description": "A single card entry in the decklist",
            "properties": {
                "quantity": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Number of copies of this card"
                },
                "name": {
                    "type": "string",
                    "description": "Exact English card name as printed"
                },
                "edition": {
                    "type": "string",
                    "description": "Set code identifying the specific printing (e.g., 'RNA', 'C16', 'MH2')"
                },
                "collector_number": {
                    "type": "string",
                    "description": "Collector number within the edition (e.g., '22', '263a')"
                },
                "primary_mechanic": {
                    "type": "string",
                    "description": "Main strategic role this card fills in the deck"
                },
                "additional_mechanics": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Additional mechanic roles or synergy labels"
                },
                "note": {
                    "type": "string",
                    "description": "Free-text note about this card's role or budget considerations"
                }
            }
        },
        "DeckRules": {
            "type": "object",
            "description": "Strategic rules for evaluating and playing this specific deck",
            "properties": {
                "mulligan": {
                    "$ref": "#/definitions/MulliganRule",
                    "description": "Opening hand evaluation rules"
                },
                "combos": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/ComboDeclaration" },
                    "description": "Known synergistic combinations in the deck"
                },
                "dont_combos": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/DontComboDeclaration" },
                    "description": "Known anti-synergies and conflicting card pairs"
                }
            }
        },
        "MulliganRule": {
            "type": "object",
            "description": "Mulligan scoring model: assign a value to each card and compare total to a threshold",
            "properties": {
                "card_values": {
                    "type": "object",
                    "description": "Default value per card category used for hand scoring",
                    "properties": {
                        "land": {
                            "type": "number",
                            "description": "Value assigned to any land card (default: 1.0)"
                        },
                        "cmc_0_to_2": {
                            "type": "number",
                            "description": "Value for non-land cards with CMC 0-2 (default: 0.8)"
                        },
                        "cmc_3": {
                            "type": "number",
                            "description": "Value for non-land cards with CMC exactly 3 (default: 0.5)"
                        },
                        "other": {
                            "type": "number",
                            "description": "Value for all other non-land cards with CMC 4+ (default: 0.3)"
                        }
                    }
                },
                "card_overrides": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/CardValueOverride" },
                    "description": "Per-card value overrides that take precedence over category defaults"
                },
                "thresholds": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/MulliganThreshold" },
                    "description": "Minimum hand value per mulligan round to decide to keep"
                }
            }
        },
        "CardValueOverride": {
            "type": "object",
            "required": ["name", "value"],
            "description": "Override the default category value for a specific card",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Exact card name"
                },
                "value": {
                    "type": "number",
                    "description": "Custom mulligan value for this card"
                },
                "reason": {
                    "type": "string",
                    "description": "Explanation for the override"
                }
            }
        },
        "MulliganThreshold": {
            "type": "object",
            "required": ["round", "min_value"],
            "description": "Minimum hand score required to keep at a given mulligan round",
            "properties": {
                "round": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Mulligan round (0 = initial 7-card hand; 1 = after first mulligan, etc.)"
                },
                "hand_size": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Expected hand size at this round (informational)"
                },
                "min_value": {
                    "type": "number",
                    "description": "Minimum total hand value required to keep"
                },
                "description": {
                    "type": "string",
                    "description": "Human-readable rule description"
                }
            }
        },
        "ComboDeclaration": {
            "type": "object",
            "required": ["id", "name", "pieces", "result"],
            "description": "A known synergistic combination of cards in the deck",
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Unique identifier for this combo within the deck"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable name for the combo"
                },
                "pieces": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string" },
                    "description": "Card names required for the combo"
                },
                "result": {
                    "type": "string",
                    "description": "Description of what the combo achieves"
                },
                "tags": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Labels such as 'infinite', 'win-condition', 'two-card'"
                }
            }
        },
        "DontComboDeclaration": {
            "type": "object",
            "required": ["id", "name", "pieces", "reason"],
            "description": "A known anti-synergy between cards in the deck",
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Unique identifier for this anti-synergy"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable name for the anti-synergy"
                },
                "pieces": {
                    "type": "array",
                    "minItems": 2,
                    "items": { "type": "string" },
                    "description": "Card names involved in the conflict"
                },
                "reason": {
                    "type": "string",
                    "description": "Explanation of why these cards conflict in this deck"
                },
                "severity": {
                    "type": "string",
                    "enum": ["critical", "major", "minor"],
                    "description": "How badly the anti-synergy affects the deck (default: 'major')"
                }
            }
        }
    }
}
